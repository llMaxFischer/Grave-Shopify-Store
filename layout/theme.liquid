    @media (min-width: 768px) {
    /* ── DESKTOP PDP: pagination dots below main image ── */
    /* The gallery is a flex-row (thumbs | main). The dots sit as a sibling.
       We use order:2 to push them after the main image, margin-left to align
       under the image (not the thumbnail column), and flex-wrap on the parent. */
    .shopify-section--product-template .product-gallery {
      flex-wrap: wrap;
    }
    .shopify-section--product-template .product-gallery__thumbnails {
      order: 0;
    }
    .shopify-section--product-template .product-gallery__main {
      order: 1;
    }
    .shopify-section--product-template .mobile-gallery-dots {
      order: 2;
      /* Push dots into the same horizontal track as the main image.
         The thumbnail column is ~130px wide (set by grave-v75.css).
         We use margin-left to skip past it so dots centre under the image. */
      width: calc(100% - 130px);
      margin-left: 130px;
      justify-content: center;
      align-items: center;
      gap: 8px;
      padding: 4px 0;
      margin-top: 18px;
    }
    }
    .shopify-section--product-template .mobile-gallery-dot {
      width: 7px;
      height: 7px;
      border-radius: 50%;
      background: #555;
      border: none;
      padding: 0;
      cursor: pointer;
      transition: background 0.2s, width 0.2s, height 0.2s;
      flex-shrink: 0;
    }
    .shopify-section--product-template .mobile-gallery-dot.is-selected {
      background: #fff;
      width: 8px;
      height: 8px;
    }

    /* ── MOBILE PDP: main image top, thumbnails horizontal squares below ── */
    @media (max-width: 767px) {
      /* Gallery: collapse flex row → block, remove fixed height, kill divider */
      .shopify-section--product-template .product-gallery {
        display: block !important;
        height: auto !important;
      }
      .shopify-section--product-template .product-gallery::after {
        display: none !important;
      }

      /* Main image: full width, no height constraint */
      .shopify-section--product-template .product-gallery__main {
        width: 100% !important;
        height: auto !important;
        display: block !important;
        margin-bottom: 0 !important;
        overflow: visible !important;
      }
      .shopify-section--product-template .product-gallery__main img {
        max-height: none !important;
        width: 100% !important;
        height: auto !important;
      }
      .product_slider {
        margin-bottom: 0 !important;
      }

      /* Hide flickity prev/next arrows and built-in page dots */
      .shopify-section--product-template .product-gallery__main .flickity-prev-next-button {
        display: none !important;
      }
      .shopify-section--product-template .product-gallery__main .flickity-page-dots {
        display: none !important;
      }

      /* Custom pagination dots — sit between image and thumbnails */
      .mobile-gallery-dots {
        display: flex;
        justify-content: center;
        align-items: center;
        gap: 8px;
        margin: 16px 0;
        padding: 8px 0;
      }
      .mobile-gallery-dot {
        display: block;
        width: 7px;
        height: 7px;
        border-radius: 50%;
        background: #555;
        border: none;
        padding: 0;
        cursor: pointer;
        transition: background 0.2s, width 0.2s, height 0.2s;
        flex-shrink: 0;
      }
      .mobile-gallery-dot.is-selected {
        background: #fff;
        width: 8px;
        height: 8px;
      }

      /* Thumbnail strip: 16px below dots */
      .shopify-section--product-template .product-gallery__thumbnails {
        position: relative !important;
        left: auto !important;
        top: auto !important;
        bottom: auto !important;
        right: auto !important;
        width: 100% !important;
        min-width: unset !important;
        height: auto !important;
        min-height: 80px !important;
        margin: 16px 0 0 0 !important;
        padding: 0 4px !important;
        opacity: 1 !important;
        display: flex !important;
        flex-direction: row !important;
        flex-wrap: nowrap !important;
        gap: 6px !important;
        overflow-x: auto !important;
        overflow-y: hidden !important;
