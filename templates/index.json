    "custom_html_cM8qtj": {
      "type": "custom-html",
      "name": "Custom HTML",
      "settings": {
        "custom_html": "<style>\n/* =========================================\n   QUICK SHOP MODAL\n   ========================================= */\n\n/* page overlay behind modal */\n.fancybox-overlay,\n.fancybox-overlay-fixed {\n  background: rgba(0, 0, 0, 0.82) !important;\n  backdrop-filter: blur(6px);\n}\n\n/* modal shell */\n.fancybox-wrap,\n.fancybox-skin,\n.fancybox-inner,\n.fancybox-content,\n.modal.fancybox-content,\n.product-quickshop__container {\n  background: #090a0c !important;\n  color: rgba(255,255,255,0.86) !important;\n  box-shadow: 0 28px 70px rgba(0,0,0,0.7) !important;\n  border: 1px solid rgba(255,255,255,0.05);\n}\n\n/* main modal body */\n.modal.fancybox-content,\n.product-quickshop__container {\n  border-radius: 14px;\n  overflow: hidden;\n}\n\n/* inner layout */\n.modal.fancybox-content .container.is-quickshop.product_section {\n  max-width: 1280px;\n  padding: 28px 28px 30px;\n  background:\n    radial-gradient(circle at 20% 20%, rgba(255, 0, 30, 0.04) 0%, transparent 18%),\n    radial-gradient(circle at 80% 75%, rgba(255, 0, 30, 0.035) 0%, transparent 18%),\n    linear-gradient(180deg, #090a0c 0%, #0c0d10 100%);\n}\n\n/* left image column */\n.modal.fancybox-content .product-gallery {\n  background: transparent;\n}\n\n.modal.fancybox-content .product-gallery__main {\n  background: #0d0f12;\n  border: 1px solid rgba(255,255,255,0.05);\n  border-radius: 10px;\n  overflow: hidden;\n  box-shadow: 0 16px 40px rgba(0,0,0,0.45);\n}\n\n.modal.fancybox-content .product-gallery__main .image__container {\n  background: #0c0e11;\n}\n\n.modal.fancybox-content .product-gallery__main img {\n  display: block;\n  width: 100%;\n  height: auto;\n}\n\n/* thumbnails */\n.modal.fancybox-content .product-gallery__thumbnails {\n  margin-top: 14px;\n}\n\n.modal.fancybox-content .product-gallery__thumbnail {\n  background: #111317;\n  border: 1px solid rgba(255,255,255,0.06);\n  border-radius: 8px;\n  overflow: hidden;\n  opacity: 0.72;\n  transition: all .22s ease;\n}\n\n.modal.fancybox-content .product-gallery__thumbnail:hover {\n  opacity: 1;\n  border-color: rgba(255, 0, 30, 0.35);\n}\n\n.modal.fancybox-content .product-gallery__thumbnail.is-nav-selected {\n  opacity: 1;\n  border-color: rgba(255, 0, 30, 0.55);\n  box-shadow: 0 0 0 1px rgba(255, 0, 30, 0.1), 0 0 18px rgba(255, 0, 30, 0.12);\n}\n\n/* gallery arrows */\n.modal.fancybox-content .flickity-prev-next-button {\n  width: 54px;\n  height: 54px;\n  border-radius: 999px;\n  background: rgba(10, 12, 14, 0.92) !important;\n  border: 1px solid rgba(255,255,255,0.08);\n  box-shadow: 0 10px 24px rgba(0,0,0,0.45);\n  transition: all .22s ease;\n}\n\n.modal.fancybox-content .flickity-prev-next-button:hover {\n  background: rgba(18, 20, 24, 0.98) !important;\n  border-color: rgba(255, 0, 30, 0.45);\n  box-shadow: 0 12px 28px rgba(0,0,0,0.55), 0 0 20px rgba(255, 0, 30, 0.14);\n}\n\n.modal.fancybox-content .flickity-prev-next-button .arrow {\n  fill: #ffffff !important;\n}\n\n/* right content column */\n.modal.fancybox-content [data-product-details] {\n  padding-left: 18px;\n}\n\n.modal.fancybox-content .product-block {\n  color: rgba(255,255,255,0.82);\n}\n\n.modal.fancybox-content .product-block h3,\n.modal.fancybox-content .product-block h1,\n.modal.fancybox-content .product-block h2 {\n  color: #ffffff;\n  font-size: 34px;\n  line-height: 1.08;\n  font-weight: 700;\n  letter-spacing: 0.01em;\n  margin-bottom: 12px;\n}\n\n.modal.fancybox-content .modal_price,\n.modal.fancybox-content .current_price,\n.modal.fancybox-content .money {\n  color: #ffffff !important;\n  font-size: 30px;\n  font-weight: 700;\n}\n\n.modal.fancybox-content .product-block--description__text,\n.modal.fancybox-content .product-block--description,\n.modal.fancybox-content .product-block p,\n.modal.fancybox-content .product-block span,\n.modal.fancybox-content .product-block label {\n  color: rgba(255,255,255,0.72);\n}\n\n.modal.fancybox-content .product-block--description__link {\n  color: rgba(255,255,255,0.92);\n  text-decoration: none;\n}\n\n.modal.fancybox-content .product-block--description__link:hover {\n  color: #ffffff;\n}\n\n.modal.fancybox-content hr {\n  border: 0;\n  border-top: 1px solid rgba(255,255,255,0.08);\n  margin: 24px 0;\n}\n\n/* hidden native select wrapper if you rely on swatches */\n.modal.fancybox-content .select label {\n  color: rgba(255,255,255,0.72);\n}\n\n.modal.fancybox-content .select select {\n  background: #111317;\n  color: #ffffff;\n  border: 1px solid rgba(255,255,255,0.1);\n}\n\n/* swatch title */\n.modal.fancybox-content .swatch .option-title {\n  color: rgba(255,255,255,0.72);\n  font-size: 14px;\n  font-weight: 600;\n  margin-bottom: 10px;\n  letter-spacing: 0.04em;\n  text-transform: uppercase;\n}\n\n/* swatches */\n.modal.fancybox-content .swatch {\n  gap: 10px;\n}\n\n.modal.fancybox-content .swatch input[type=radio] {\n  display: none !important;\n}\n\n.modal.fancybox-content .swatch .swatch-element {\n  margin: 0 0 10px 0;\n}\n\n.modal.fancybox-content .swatch .swatch-element label {\n  min-width: 54px;\n  min-height: 44px;\n  padding: 0 14px;\n  display: inline-flex;\n  align-items: center;\n  justify-content: center;\n  background: #111317;\n  color: rgba(255,255,255,0.86);\n  border: 1px solid rgba(255,255,255,0.10);\n  border-radius: 6px;\n  box-shadow: none;\n  transition: all .22s ease;\n}\n\n.modal.fancybox-content .swatch .swatch-element label:hover {\n  border-color: rgba(255, 0, 30, 0.35);\n  color: #ffffff;\n}\n\n/* selected swatch */\n.modal.fancybox-content .swatch input[type=radio]:checked + .swatch-element label,\n.modal.fancybox-content .swatch .swatch-element input:checked + label {\n  background: linear-gradient(180deg, #1a1012 0%, #12090b 100%);\n  color: #ffffff;\n  border-color: rgba(255, 0, 30, 0.6);\n  box-shadow: 0 0 0 1px rgba(255,0,30,0.12), 0 0 22px rgba(255,0,30,0.12);\n}\n\n/* purchase area */\n.modal.fancybox-content .purchase-details {\n  margin-top: 18px;\n}\n\n.modal.fancybox-content .purchase-details__buttons,\n.modal.fancybox-content .atc-btn-container {\n  display: flex;\n  flex-direction: column;\n  gap: 10px;\n  align-items: stretch;\n  max-width: 360px;\n}\n\n/* add to cart */\n.modal.fancybox-content .action_button.add_to_cart,\n.modal.fancybox-content .ajax-submit.action_button.add_to_cart {\n  width: 100%;\n  justify-content: center;\n  min-height: 56px;\n  background: linear-gradient(180deg, #b81f1f 0%, #7b1616 100%) !important;\n  color: #ffffff !important;\n  border: 1px solid rgba(255, 40, 40, 0.5) !important;\n  box-shadow:\n    0 10px 24px rgba(0,0,0,0.6),\n    0 0 20px rgba(255, 20, 20, 0.2);\n}\n\n.modal.fancybox-content .action_button.add_to_cart:hover,\n.modal.fancybox-content .ajax-submit.action_button.add_to_cart:hover {\n  color: #ffffff !important;\n  border-color: rgba(255,80,80,0.9) !important;\n  box-shadow:\n    0 14px 32px rgba(0,0,0,0.7),\n    0 0 40px rgba(255, 0, 30, 0.45),\n    0 0 90px rgba(255, 0, 30, 0.30);\n}\n\n/* buy now */\n.modal.fancybox-content .shopify-payment-button,\n.modal.fancybox-content shopify-buy-it-now-button {\n  width: 100%;\n}\n\n.modal.fancybox-content .shopify-payment-button__button.shopify-payment-button__button--unbranded {\n  width: 100%;\n  min-height: 54px;\n  border-radius: 4px !important;\n  border: 1px solid rgba(255,255,255,0.08) !important;\n  background: #131417 !important;\n  color: #ffffff !important;\n  font-weight: 700;\n  letter-spacing: 0.08em;\n  text-transform: uppercase;\n  box-shadow: none !important;\n}\n\n.modal.fancybox-content .shopify-payment-button__button.shopify-payment-button__button--unbranded:hover {\n  background: #17191d !important;\n  border-color: rgba(255, 0, 30, 0.35) !important;\n  box-shadow: 0 0 18px rgba(255,0,30,0.1) !important;\n}\n\n/* close button */\n.modal.fancybox-content .fancybox-close,\n.product-quickshop__container .fancybox-close {\n  top: 18px !important;\n  right: 18px !important;\n  width: 42px !important;\n  height: 42px !important;\n  border-radius: 999px;\n  background: rgba(10, 12, 14, 0.92) !important;\n  border: 1px solid rgba(255,255,255,0.08);\n  box-shadow: 0 10px 24px rgba(0,0,0,0.45);\n  transition: all .22s ease;\n}\n\n.modal.fancybox-content .fancybox-close:hover,\n.product-quickshop__container .fancybox-close:hover {\n  border-color: rgba(255, 0, 30, 0.45);\n  box-shadow: 0 12px 28px rgba(0,0,0,0.55), 0 0 20px rgba(255, 0, 30, 0.14);\n}\n\n/* create the X if theme sprite is weak */\n.modal.fancybox-content .fancybox-close::before,\n.modal.fancybox-content .fancybox-close::after,\n.product-quickshop__container .fancybox-close::before,\n.product-quickshop__container .fancybox-close::after {\n  content: \"\";\n  position: absolute;\n  left: 50%;\n  top: 50%;\n  width: 18px;\n  height: 2px;\n  background: #ffffff;\n  transform-origin: center;\n}\n\n.modal.fancybox-content .fancybox-close::before,\n.product-quickshop__container .fancybox-close::before {\n  transform: translate(-50%, -50%) rotate(45deg);\n}\n\n.modal.fancybox-content .fancybox-close::after,\n.product-quickshop__container .fancybox-close::after {\n  transform: translate(-50%, -50%) rotate(-45deg);\n}\n\n/* responsive */\n@media (max-width: 980px) {\n  .modal.fancybox-content .container.is-quickshop.product_section {\n    padding: 18px 18px 22px;\n  }\n\n  .modal.fancybox-content [data-product-details] {\n    padding-left: 0;\n    margin-top: 18px;\n  }\n\n  .modal.fancybox-content .product-block h3 {\n    font-size: 28px;\n  }\n\n  .modal.fancybox-content .modal_price,\n  .modal.fancybox-content .current_price,\n  .modal.fancybox-content .money {\n    font-size: 24px;\n  }\n}\n\n@media (max-width: 767px) {\n  .modal.fancybox-content .container.is-quickshop.product_section {\n    padding: 14px 14px 18px;\n  }\n\n  .modal.fancybox-content .product-gallery__main {\n    border-radius: 8px;\n  }\n\n  .modal.fancybox-content .product-gallery__thumbnail {\n    border-radius: 6px;\n  }\n\n  .modal.fancybox-content .purchase-details__buttons,\n  .modal.fancybox-content .atc-btn-container {\n    max-width: 100%;\n  }\n\n  .modal.fancybox-content .action_button.add_to_cart,\n  .modal.fancybox-content .shopify-payment-button__button.shopify-payment-button__button--unbranded {\n    min-height: 50px;\n  }\n}\n</style>"
