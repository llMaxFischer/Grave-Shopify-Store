    "custom_html_7RcqAm": {
      "type": "custom-html",
      "name": "Custom HTML",
      "settings": {
        "custom_html": "<style>\n/* =========================================\n   PRODUCT HOVER — ZOOM + DARK OVERLAY\n   ========================================= */\n\n/* ensure container is ready */\n.thumbnail__image,\n.image__container {\n  position: relative;\n  overflow: hidden;\n}\n\n/* smooth image scaling */\n.thumbnail__image img,\n.image__container img {\n  transition: transform 0.6s ease, filter 0.6s ease;\n  will-change: transform;\n}\n\n/* overlay layer */\n.image__container::after {\n  content: \"\";\n  position: absolute;\n  inset: 0;\n  background: rgba(0, 0, 0, 0);\n  transition: background 0.4s ease;\n  pointer-events: none;\n  z-index: 2;\n}\n\n/*  HOVER EFFECT */\n.thumbnail:hover .image__container img {\n  transform: scale(1.06); /* subtle zoom */\n}\n\n/* dark overlay */\n.thumbnail:hover .image__container::after {\n  background: rgba(0, 0, 0, 0.28);\n}\n</style>"
      }
    },
    "custom_html_DXhENz": {
      "type": "custom-html",
      "name": "Custom HTML",
      "settings": {
        "custom_html": "<style>\n/* =========================================\n   FOOTER V2 — CLOSER TO REFERENCE\n   ========================================= */\n\n.footer {\n  position: relative;\n  background: linear-gradient(180deg, #19191b 0%, #1d1d20 100%);\n  color: rgba(255,255,255,0.88);\n  overflow: hidden;\n}\n\n.footer .section {\n  padding: 72px 0 26px;\n}\n\n.footer .container {\n  max-width: 1320px;\n  margin: 0 auto;\n  display: flex;\n  flex-wrap: wrap;\n  align-items: flex-start;\n  position: relative;\n}\n\n/* =========================================\n   LEFT BRAND COLUMN\n   ========================================= */\n.footer .three-sevenths.columns {\n  width: 28%;\n  padding: 0 44px 0 10px;\n  position: relative;\n  min-height: 320px;\n  display: flex;\n  flex-direction: column;\n  justify-content: center;\n}\n\n/* vertical divider */\n.footer .three-sevenths.columns::after {\n  content: \"\";\n  position: absolute;\n  top: 4px;\n  right: 0;\n  width: 1px;\n  height: 345px;\n  background: rgba(255,255,255,0.38);\n}\n\n/* hide raw Follow title */\n.footer .footer__title,\n.footer .three-sevenths.columns > h6 {\n  display: none !important;\n}\n\n/* faux logo lockup */\n.footer .three-sevenths.columns::before {\n  content: \"GRAVE\\AAPPAREL CO.\\A\\ADark Fantasy Inspired Apparel\";\n  white-space: pre;\n  display: block;\n  color: #ffffff;\n  line-height: 1.15;\n  letter-spacing: 0.01em;\n  font-size: 17px;\n  font-weight: 500;\n  max-width: 260px;\n}\n\n/* make first word feel like logo */\n.footer .three-sevenths.columns {\n  font-family: inherit;\n}\n\n/* left social hidden in desktop v2 */\n.footer .three-sevenths.columns .js-social-icons {\n  display: none;\n}\n\n/* =========================================\n   RIGHT FOOTER GRID\n   ========================================= */\n.footer .four-sevenths.columns {\n  width: 72%;\n  padding: 0 10px 0 46px;\n  display: grid;\n  grid-template-columns: 1fr 1fr 1.35fr;\n  column-gap: 48px;\n  row-gap: 16px;\n  align-items: start;\n}\n\n/* =========================================\n   MENU LINKS AREA\n   ========================================= */\n.footer .footer_menu {\n  grid-column: 1 / 3;\n  list-style: none;\n  padding: 0;\n  margin: 0;\n  display: grid;\n  grid-template-columns: repeat(2, minmax(160px, 1fr));\n  gap: 16px 28px;\n  max-width: 470px;\n}\n\n.footer .footer_menu li {\n  margin: 0;\n  padding: 0;\n}\n\n.footer .footer_menu a {\n  color: rgba(255,255,255,0.92);\n  text-decoration: none;\n  font-size: 15px;\n  line-height: 1.45;\n  font-weight: 400;\n  transition: opacity .22s ease, color .22s ease;\n}\n\n.footer .footer_menu a:hover {\n  opacity: 0.72;\n  color: #ffffff;\n}\n\n/* =========================================\n   NEWSLETTER BLOCK\n   ========================================= */\n.footer .four-sevenths.columns > p {\n  grid-column: 3;\n  grid-row: 1;\n  margin: 0 0 10px;\n  max-width: 390px;\n  color: rgba(255,255,255,0.80);\n  font-size: 14px;\n  line-height: 1.45;\n  position: relative;\n  padding-top: 42px;\n}\n\n/* heading above paragraph */\n.footer .four-sevenths.columns > p::before {\n  content: \"Join our email list\";\n  position: absolute;\n  top: 0;\n  left: 0;\n  color: #ffffff;\n  font-size: 18px;\n  line-height: 1.2;\n  font-weight: 500;\n}\n\n/* form placement */\n.footer .newsletter {\n  grid-column: 3;\n  grid-row: 2;\n  max-width: 410px;\n  margin: 0;\n}\n\n.footer .newsletter .input-row {\n  display: flex;\n  align-items: center;\n  gap: 0;\n  position: relative;\n}\n\n/* email pill */\n.footer .newsletter .contact_email {\n  width: 100%;\n  min-height: 54px;\n  border-radius: 999px;\n  border: 0;\n  background: #ececed;\n  color: #1a1a1d;\n  padding: 0 62px 0 22px;\n  font-size: 15px;\n  box-sizing: border-box;\n}\n\n.footer .newsletter .contact_email::placeholder {\n  color: rgba(0,0,0,0.52);\n}\n\n.footer .newsletter .contact_email:focus {\n  outline: none;\n}\n\n/* submit becomes arrow */\n.footer .newsletter .action_button.sign_up {\n  position: absolute;\n  right: 8px;\n  top: 50%;\n  transform: translateY(-50%);\n  width: 36px;\n  min-width: 36px;\n  height: 36px;\n  min-height: 36px;\n  padding: 0 !important;\n  border: 0 !important;\n  border-radius: 999px !important;\n  background: transparent !important;\n  box-shadow: none !important;\n  color: transparent !important;\n  font-size: 0 !important;\n  overflow: visible !important;\n}\n\n.footer .newsletter .action_button.sign_up::before,\n.footer .newsletter .action_button.sign_up::after {\n  display: none !important;\n  content: none !important;\n}\n\n.footer .newsletter .action_button.sign_up:hover {\n  background: transparent !important;\n  box-shadow: none !important;\n  transform: translateY(-50%) !important;\n}\n\n/* arrow glyph */\n.footer .newsletter .action_button.sign_up {\n  position: absolute;\n}\n\n.footer .newsletter .action_button.sign_up:after {\n  content: \"→\" !important;\n  display: block !important;\n  font-size: 24px !important;\n  line-height: 36px !important;\n  color: #4a4a4d !important;\n  text-align: center;\n  width: 36px;\n  height: 36px;\n}\n\n/* =========================================\n   SOCIAL ICONS RIGHT SIDE\n   ========================================= */\n.footer .newsletter::after {\n  content: \"\";\n  display: block;\n  clear: both;\n}\n\n.footer .newsletter + style + .footer__info,\n.footer .newsletter + .footer__info {\n  grid-column: 1 / 4;\n}\n\n/* move social icons visually to right block */\n.footer .four-sevenths.columns::before {\n  content: \"\";\n  grid-column: 3;\n  grid-row: 3;\n  height: 1px;\n}\n\n.footer .four-sevenths.columns .js-social-icons {\n  grid-column: 3;\n  grid-row: 3;\n  justify-self: end;\n  margin-top: 6px;\n}\n\n.footer .four-sevenths.columns .social-icons {\n  display: flex;\n  gap: 14px;\n  align-items: center;\n  justify-content: flex-end;\n}\n\n.footer .four-sevenths.columns .social-icons a {\n  width: auto;\n  height: auto;\n  border: 0;\n  border-radius: 0;\n  background: transparent;\n  color: rgba(255,255,255,0.92);\n  display: inline-flex;\n  align-items: center;\n  justify-content: center;\n  font-size: 30px;\n  line-height: 1;\n  text-decoration: none;\n  box-shadow: none;\n  transition: opacity .22s ease, transform .22s ease;\n}\n\n.footer .four-sevenths.columns .social-icons a:hover {\n  opacity: 0.75;\n  transform: translateY(-1px);\n}\n\n.footer .four-sevenths.columns .social-icons a[href=\"\"] {\n  display: none !important;\n}\n\n/* =========================================\n   LEGAL / CREDITS\n   ========================================= */\n.footer .footer__info {\n  grid-column: 1 / 4;\n  margin-top: 58px;\n  padding-top: 0;\n  border-top: 0;\n}\n\n.footer .credits {\n  margin: 0;\n  font-size: 12px;\n  line-height: 1.5;\n  color: rgba(255,255,255,0.66);\n}\n\n.footer .credits a {\n  color: rgba(255,255,255,0.66);\n  text-decoration: none;\n}\n\n.footer .credits a:hover {\n  color: #ffffff;\n}\n\n/* tighten shopify/privacy icon */\n.footer .shopify-dns-link-icon {\n  opacity: 0.82;\n  margin-left: 0.3em !important;\n}\n\n/* =========================================\n   OPTIONAL LOGO FONT TREATMENT\n   ========================================= */\n.footer .three-sevenths.columns::before {\n  text-shadow: 0 1px 0 rgba(255,255,255,0.02);\n}\n\n/* =========================================\n   MOBILE / TABLET\n   ========================================= */\n@media (max-width: 1100px) {\n  .footer .three-sevenths.columns {\n    width: 100%;\n    padding: 0 20px 32px;\n    min-height: auto;\n  }\n\n  .footer .three-sevenths.columns::after {\n    display: none;\n  }\n\n  .footer .three-sevenths.columns .js-social-icons {\n    display: block;\n    margin-top: 22px;\n  }\n\n  .footer .three-sevenths.columns .social-icons {\n    display: flex;\n    gap: 12px;\n  }\n\n  .footer .three-sevenths.columns .social-icons a {\n    width: 40px;\n    height: 40px;\n    border-radius: 999px;\n    border: 1px solid rgba(255,255,255,0.18);\n    display: inline-flex;\n    align-items: center;\n    justify-content: center;\n    color: #ffffff;\n    text-decoration: none;\n  }\n\n  .footer .four-sevenths.columns {\n    width: 100%;\n    padding: 0 20px;\n    grid-template-columns: 1fr;\n    column-gap: 0;\n    row-gap: 20px;\n  }\n\n  .footer .footer_menu {\n    grid-column: auto;\n    max-width: none;\n  }\n\n  .footer .four-sevenths.columns > p,\n  .footer .newsletter,\n  .footer .four-sevenths.columns .js-social-icons,\n  .footer .footer__info {\n    grid-column: auto;\n    grid-row: auto;\n    max-width: 100%;\n    justify-self: start;\n  }\n\n  .footer .four-sevenths.columns .js-social-icons {\n    display: none;\n  }\n\n  .footer .footer__info {\n    margin-top: 26px;\n  }\n}\n\n@media (max-width: 767px) {\n  .footer .section {\n    padding: 46px 0 22px;\n  }\n\n  .footer .three-sevenths.columns::before {\n    font-size: 15px;\n    line-height: 1.7;\n  }\n\n  .footer .footer_menu {\n    grid-template-columns: 1fr 1fr;\n    gap: 12px 18px;\n  }\n\n  .footer .newsletter .contact_email {\n    min-height: 50px;\n    padding-left: 18px;\n    padding-right: 56px;\n  }\n\n  .footer .newsletter .action_button.sign_up {\n    right: 7px;\n  }\n}\n</style>"
