      "name": "Custom HTML",
      "settings": {
        "custom_html": "<style>\n/* =========================================\n   QUICK SHOP FIX\n   ========================================= */\n\n/* fix container */\n.thumbnail,\n.product-thumbnail,\n.image__container {\n  position: relative;\n  overflow: hidden;\n}\n\n/* reset + style */\n.quick_shop.quick_shop--button {\n  position: absolute !important;\n  left: 50%;\n  bottom: 18px;\n\n  transform: translateX(-50%) translateY(10px);\n\n  display: inline-flex !important;\n  align-items: center;\n  justify-content: center;\n  gap: 8px;\n\n  width: auto !important;\n  max-width: calc(100% - 24px);\n  padding: 12px 20px !important;\n\n  /* 🔥 MATCH YOUR RED BUTTON SYSTEM */\n  background: linear-gradient(180deg, #9e1c1c 0%, #7b1616 100%);\n  color: #ffffff !important;\n\n  border: 1px solid rgba(255, 40, 40, 0.45);\n  border-radius: 999px;\n\n  font-size: 13px;\n  font-weight: 700;\n  letter-spacing: 0.08em;\n  text-transform: uppercase;\n\n  box-shadow:\n    0 10px 24px rgba(0,0,0,0.55),\n    0 0 12px rgba(255,40,40,0.25);\n\n  opacity: 0;\n  visibility: hidden;\n  z-index: 20;\n\n  transition:\n    opacity 0.25s ease,\n    transform 0.25s ease,\n    box-shadow 0.3s ease,\n    border-color 0.25s ease;\n}\n\n/* remove theme junk */\n.quick_shop.quick_shop--button::before,\n.quick_shop.quick_shop--button::after {\n  display: none !important;\n}\n\n/* icon */\n.quick_shop.quick_shop--button .icon-search {\n  font-size: 14px;\n}\n\n/* show on hover */\n.thumbnail:hover .quick_shop.quick_shop--button,\n.product-thumbnail:hover .quick_shop.quick_shop--button,\n.image__container:hover .quick_shop.quick_shop--button {\n  opacity: 1;\n  visibility: visible;\n  transform: translateX(-50%) translateY(0);\n}\n\n/* 🔥 HOVER (MATCHES HERO BUTTON GLOW) */\n.quick_shop.quick_shop--button:hover {\n  border-color: rgba(255,80,80,0.8);\n\n  box-shadow:\n    0 14px 28px rgba(0,0,0,0.65),\n    0 0 22px rgba(255, 0, 30, 0.5),\n    0 0 55px rgba(255, 0, 30, 0.38),\n    0 0 90px rgba(255, 0, 30, 0.25);\n\n  color: #ffffff !important;\n}\n\n/* mobile */\n@media (max-width: 767px) {\n  .quick_shop.quick_shop--button {\n    opacity: 1;\n    visibility: visible;\n    transform: translateX(-50%) translateY(0);\n    bottom: 12px;\n  }\n}\n</style>"
      }
