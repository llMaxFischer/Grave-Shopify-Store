{% assign about_img = 'about-v4.png' | asset_url %}
{% assign content = content | replace: 'https://cdn.shopify.com/s/files/1/0705/8872/7478/files/Grave_About_Me_Image_2.png?v=1761431917', about_img %}
{% if page.id == 110479868086 %}
<style>
.container.main-wrapper { max-width: none !important; margin-bottom: 0 !important; }
.one-whole.column > div[style*="margin"] { max-width: 1760px !important; width: 100% !important; }
.one-whole.column :is(p,h3) { font-family: 'Acumin Pro','Acumin Pro Condensed','Helvetica Neue',Helvetica,Arial,sans-serif !important; font-size: 22px !important; line-height: 1.5 !important; letter-spacing: -0.02em !important; }
</style>
{% endif %}
{% assign cols = content | split: '<!-- split -->' %}
{% if cols.size == 2 %}
  <div
    class="
      one-half
      column
      medium-down--one-whole
    "
  >
    {{ cols[0] }}
  </div>

  <div
    class="
      one-half
      column
      medium-down--one-whole
    "
  >
    {{ cols[1] }}
  </div>
{% elsif cols.size == 3 %}
  <div
    class="
      one-third
      column
      medium-down--one-whole
    "
  >
    {{ cols[0] }}
  </div>

  <div
    class="
      one-third
      column
      medium-down--one-whole
    "
  >
    {{ cols[1] }}
  </div>

  <div
    class="
      one-third
      column
      medium-down--one-whole
    "
  >
    {{ cols[2] }}
  </div>
{% elsif cols.size == 4 %}
  <div
    class="
      one-fourth
      column
      medium-down--one-whole
    "
  >
    {{ cols[0] }}
  </div>

  <div
    class="
      one-fourth
      column
      medium-down--one-whole
    "
  >
    {{ cols[1] }}
  </div>

  <div
    class="
      one-fourth
      column
      medium-down--one-whole
    "
  >
    {{ cols[2] }}
  </div>

  <div
    class="
      one-fourth
      column
      medium-down--one-whole
    "
  >
    {{ cols[3] }}
  </div>
{% else %}
  <div class="one-whole column">
    {{ content }}
  </div>
{% endif %}

<script>
(function() {
  var imgs = document.querySelectorAll('.container.main-wrapper img[src*="Grave_About_Me_Image_2"]');
  if (imgs.length) {
    imgs[0].src = '{{ "about-v4.png" | asset_url }}';
  }
})();
</script>
