{% assign content = content | replace: 'https://cdn.shopify.com/s/files/1/0705/8872/7478/files/Grave_About_Me_Image_2.png?v=1761431917',     'https://cdn.shopify.com/s/files/1/0705/8872/7478/t/5/assets/about-v4.png?v=1780864576' %}
{% if page.id == 110479868086 %}
<style>
.container.main-wrapper { max-width: none !important; margin-bottom: 0 !important; }
.one-whole.column > div[style*="margin"] { max-width: 1760px !important; width: 100% !important; }
.one-whole.column p { font-family: 'Acumin Pro','Acumin Pro Condensed','Helvetica Neue',Helvetica,Arial,sans-serif !important; font-size: 28px !important; }
</style>
{% endif %}
{% if page.id == 110479671478 %}
<style>
body.page .container.main-wrapper { max-width: 900px !important; }
body.page .container.main-wrapper > .one-whole.column p,
body.page .container.main-wrapper > .one-whole.column li {
  font-size: 16px !important;
  font-weight: normal !important;
  font-family: 'Acumin Pro','Acumin Pro Condensed','Helvetica Neue',Helvetica,Arial,sans-serif !important;
}
body.page .container.main-wrapper > .one-whole.column ul li strong,
body.page .container.main-wrapper > .one-whole.column ul li b {
  font-weight: normal !important;
}
body.page .container.main-wrapper > .one-whole.column h2,
body.page .container.main-wrapper > .one-whole.column h3 {
  font-size: 19px !important;
  font-weight: 600 !important;
  margin-top: 24px !important;
  margin-bottom: 4px !important;
}
body.page .container.main-wrapper > .one-whole.column:last-child {
  padding-top: 32px !important;
  padding-bottom: 80px !important;
}
</style>
{% endif %}
{% assign cols = content | split: '<!-- split -->' %}
{% if cols.size == 2 %}
  <div
    class="
      one-half
      column
      medium-down--one-whole
    "
  >
    {{ cols[0] }}
  </div>

  <div
    class="
      one-half
      column
      medium-down--one-whole
    "
  >
    {{ cols[1] }}
  </div>
{% elsif cols.size == 3 %}
  <div
    class="
      one-third
      column
      medium-down--one-whole
    "
  >
    {{ cols[0] }}
  </div>

  <div
    class="
      one-third
      column
      medium-down--one-whole
    "
  >
    {{ cols[1] }}
  </div>

  <div
    class="
      one-third
      column
      medium-down--one-whole
    "
  >
    {{ cols[2] }}
  </div>
{% elsif cols.size == 4 %}
  <div
    class="
      one-fourth
      column
      medium-down--one-whole
    "
  >
    {{ cols[0] }}
  </div>

  <div
    class="
      one-fourth
      column
      medium-down--one-whole
    "
  >
    {{ cols[1] }}
  </div>

  <div
    class="
      one-fourth
      column
      medium-down--one-whole
    "
  >
    {{ cols[2] }}
  </div>

  <div
    class="
      one-fourth
      column
      medium-down--one-whole
    "
  >
    {{ cols[3] }}
  </div>
{% else %}
  <div class="one-whole column">
    {{ content }}
  </div>
{% endif %}

<script>
(function() {
  var imgs = document.querySelectorAll('.container.main-wrapper img[src*="Grave_About_Me_Image_2"]');
  if (imgs.length) {
    imgs[0].src = 'https://cdn.shopify.com/s/files/1/0705/8872/7478/t/5/assets/about-v4.png?v=1780864576';
  }
})();
</script>
