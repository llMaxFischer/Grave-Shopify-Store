<section class="section">
  <div class="container main-wrapper">
    <div
      class="
        one-whole
        column
        page
      "
    >
      <h1 class="center">
        {{ page.title }}
      </h1>

      <div class="feature_divider"></div>
    </div>

    {%
      render 'page-multi-column',
      content: page.content,
    %}
  </div>
  <!-- page-{{ page.id }} -->
  <style>
    #shopify-section-{{ section.id }} .container.main-wrapper { max-width: none !important; margin-bottom: 0 !important; }
    #shopify-section-{{ section.id }} .one-whole.column > div[style*="margin"] { max-width: 1760px !important; width: 100% !important; }
    #shopify-section-{{ section.id }} .one-whole.column p { font-family: 'Acumin Pro', 'Acumin Pro Condensed', 'Helvetica Neue', Helvetica, Arial, sans-serif !important; font-size: 28px !important; }
  </style>
</section>
