<style>
  .shopify-section--marquee-banner {
    margin-top: 0 !important;
    margin-left: 0 !important;
    margin-right: 0 !important;
    padding-top: 0 !important;
    padding-left: 0 !important;
    padding-right: 0 !important;
    background: #540c1f;
  }

  .shopify-section--image-with-text-overlay-section {
    margin-bottom: 0 !important;
    padding-bottom: 0 !important;
  }

  .marquee-banner__wrapper {
    width: 100vw;
    margin-left: calc(-50vw + 50%);
    overflow: hidden;
    background: #540c1f;
    line-height: 0;
  }

  .marquee-banner__track {
    display: flex;
    width: 200vw;
    animation: marqueeScroll 40s linear infinite;
  }

  .marquee-banner__item {
    flex: 0 0 100vw;
    overflow: visible;
  }

  .marquee-banner__item img {
    display: block;
    width: calc(100vw + 1px);
    height: auto;
    margin-right: -1px;
  }

  @keyframes marqueeScroll {
    0% { transform: translateX(0); }
    100% { transform: translateX(-100vw); }
  }

  @keyframes marqueeMobileScroll {
    0% { transform: translateX(0); }
    100% { transform: translateX(-150vw); }
  }

  @media (max-width: 767px) {
    .marquee-banner__track {
      width: 450vw !important;
      animation-name: marqueeMobileScroll !important;
      animation-duration: 40s !important;
    }
    .marquee-banner__item {
      flex: 0 0 225vw !important;
    }
    .marquee-banner__desktop-img {
      display: none !important;
    }
    .marquee-banner__mobile-img {
      display: block !important;
      width: calc(225vw + 1px) !important;
      height: auto !important;
      margin-right: -1px !important;
    }
  }
</style>

<div class="marquee-banner__wrapper">
  <div class="marquee-banner__track">
    <div class="marquee-banner__item">
      <img class="marquee-banner__desktop-img" src="{{ 'stay-haunted-banner.svg' | asset_url }}" alt="Stay Haunted" loading="eager">
      <img class="marquee-banner__mobile-img" src="{{ 'Stay Haunted Scroll Banner MOBILE.svg' | asset_url }}" alt="Stay Haunted" loading="eager" style="display:none">
    </div>
    <div class="marquee-banner__item">
      <img class="marquee-banner__desktop-img" src="{{ 'stay-haunted-banner.svg' | asset_url }}" alt="Stay Haunted" loading="eager">
      <img class="marquee-banner__mobile-img" src="{{ 'Stay Haunted Scroll Banner MOBILE.svg' | asset_url }}" alt="Stay Haunted" loading="eager" style="display:none">
    </div>
  </div>
</div>

{% schema %}
  {
    "name": "Marquee Banner",
    "class": "shopify-section--marquee-banner",
    "settings": [],
    "presets": [{
      "name": "Marquee Banner",
      "category": "Content"
    }],
    "enabled_on": {
      "templates": ["index"]
    }
  }
{% endschema %}