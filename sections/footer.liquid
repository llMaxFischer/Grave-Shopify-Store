        <ul class="footer-reference__menu footer-reference__menu--col2">
          <li><a href="/pages/about">About Us</a></li>
          <li><a href="/pages/contact">Contact</a></li>
          <li><a href="/pages/faq">FAQ</a></li>
          <li><a href="/pages/return-policy">Return Policy</a></li>
          <li><a href="/collections/hats">Hats</a></li>
        </ul>
      </div>

      <div class="footer-reference__newsletter">
        <h3 class="footer-reference__newsletter-title">Join Our Email List</h3>

        {% if section.settings.richtext != blank %}
          <div class="footer-reference__newsletter-copy">
            {{ section.settings.richtext }}
          </div>
        {% else %}
          <div class="footer-reference__newsletter-copy">
            <p>Get exclusive deals and early access to new products.</p>
          </div>
        {% endif %}

        <div class="footer-reference__newsletter-form">
          {% render 'newsletter',
            context: 'footer',
            first_name: section.settings.display_first_name,
            last_name: section.settings.display_last_name
          %}
        </div>

        <div class="footer-reference__social">
          <a href="{{ settings.facebook_link }}" target="_blank" title="Facebook" class="footer-reference__social-link">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="24.8 58 28 28" width="30" height="30" class="footer-reference__social-icon">
