              <path d="M79.63,85.54h-10.81c-4.48,0-8.13-3.65-8.13-8.13v-10.81c0-4.48,3.65-8.13,8.13-8.13h10.81c4.48,0,8.13,3.65,8.13,8.13v10.81c0,4.48-3.65,8.13-8.13,8.13ZM68.82,61.01c-3.08,0-5.59,2.51-5.59,5.59v10.81c0,3.08,2.51,5.59,5.59,5.59h10.81c3.08,0,5.59-2.51,5.59-5.59v-10.81c0-3.08-2.51-5.59-5.59-5.59h-10.81Z"/>
            </svg>
          </a>
          <a href="https://www.tiktok.com/@grave.apparel.co" target="_blank" title="TikTok" class="footer-reference__social-link">
