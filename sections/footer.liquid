            <svg xmlns="http://www.w3.org/2000/svg" viewBox="60.2 58 28 28" width="30" height="30" class="footer-reference__social-icon">
              <path d="M81.39,63.3c-.88,0-1.59.71-1.59,1.59s.71,1.59,1.59,1.59,1.59-.71,1.59-1.59-.71-1.59-1.59-1.59Z"/>
