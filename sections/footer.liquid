          <li><a href="/collections/t-shirts-2">T-shirts</a></li>
          <li><a href="/collections/long-sleeve-shirts-1">Long Sleeve Shirts</a></li>
          <li><a href="/collections/hoodies">Hoodies</a></li>
          <li><a href="/collections/pins">Accessories</a></li>
