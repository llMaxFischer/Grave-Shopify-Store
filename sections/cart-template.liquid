{%- capture taxes_shipping_checkout -%}
  {%- if cart.taxes_included and shop.shipping_policy.body != blank -%}
    {{ 'cart.general.taxes_included_and_shipping_policy_html' | t: link: shop.shipping_policy.url }}
  {%- elsif cart.taxes_included -%}
    {{ 'cart.general.taxes_included_but_shipping_at_checkout' | t }}
  {%- elsif shop.shipping_policy.body != blank -%}
    {{ 'cart.general.taxes_and_shipping_policy_at_checkout_html' | t: link: shop.shipping_policy.url }}
  {%- else -%}
    {{ 'cart.general.tax_and_shipping' | t }}
  {%- endif -%}
{%- endcapture -%}

{% liquid
  if section.settings.continue_shopping_link == blank
    if cart.items.first.product.collections != blank
      assign continue_shopping_link = cart.items.first.product.collections.last.url
    else
      assign continue_shopping_link = routes.all_products_collection_url
    endif
  else
    assign continue_shopping_link = section.settings.continue_shopping_link
  endif
%}

<section class="section">
  <div class="cart-page__wrapper">

    <!-- Page header: title + continue shopping -->
    <div class="cart-page__header">
      <h1 class="cart-page__title">{{ 'cart.general.title' | t }}</h1>
      {% if section.settings.display_continue_shopping %}
        <a href="{{ continue_shopping_link }}" class="cart-page__continue-link">{{ 'cart.general.continue_shopping_link_html' | t }}</a>
      {% endif %}
    </div>

    {% if cart.item_count == 0 %}
      <div class="cart-page__empty">
        <p>
          {%- if section.settings.display_continue_shopping -%}
            {{- 'cart.general.continue_browsing_html' | t: link: continue_shopping_link -}}
          {%- else -%}
            {{- 'cart.general.continue_browsing_text' | t -}}
          {%- endif -%}
        </p>
      </div>
    {% else %}

      <form action="{{ routes.cart_url }}" method="post" id="cart_form">

        <!-- Column headers -->
        <div class="cart-table__header">
          <div class="cart-table__col cart-table__col--product">Product</div>
          <div class="cart-table__col cart-table__col--price">Price</div>
          <div class="cart-table__col cart-table__col--quantity">Quantity</div>
          <div class="cart-table__col cart-table__col--total">Total</div>
        </div>

        <!-- Cart items -->
        <div class="cart-table__body">
          {% for item in cart.items %}
            <div class="cart-table__row">

              <!-- Product: image + title + variants -->
              <div class="cart-table__col cart-table__col--product">
                <a href="{{ item.url }}" class="cart-item__image-link">
                  {% if item.image != blank %}
                    {%
                      render 'image-element',
                      image: item.image,
                      alt: item.title,
                    %}
                  {% endif %}
                </a>
                <div class="cart-item__details">
                  <a href="{{ item.url }}" class="cart-item__title">{{ item.product.title }}</a>

                  {%- if item.product.has_only_default_variant == false
                    or item.properties.size != 0
                    or item.selling_plan_allocation != null
                  -%}
                    <ul class="cart__product-options">
                      {%- if item.product.has_only_default_variant == false -%}
                        {%- for option in item.options_with_values -%}
                          {%- assign opt_name_lower = option.name | downcase -%}
                          {%- if opt_name_lower == 'make a choice' or opt_name_lower == 'title' -%}
                            {%- assign display_name = 'Size' -%}
                          {%- else -%}
                            {%- assign display_name = option.name -%}
                          {%- endif -%}
                          {%- assign opt_val_lower = option.value | downcase -%}
                          {%- case opt_val_lower -%}
                            {%- when 'small' -%}{%- assign display_value = 'S' -%}
                            {%- when 'medium' -%}{%- assign display_value = 'M' -%}
                            {%- when 'large' -%}{%- assign display_value = 'L' -%}
                            {%- when 'x-large' or 'xlarge' or 'xl' -%}{%- assign display_value = 'XL' -%}
                            {%- when 'xx-large' or 'xxlarge' or '2xl' or 'xxl' -%}{%- assign display_value = '2XL' -%}
                            {%- when 'xxx-large' or 'xxxlarge' or '3xl' or 'xxxl' -%}{%- assign display_value = '3XL' -%}
                            {%- else -%}{%- assign display_value = option.value -%}
                          {%- endcase -%}
                          <li class="cart__product-option">
                            <span class="cart__product-option-name">{{- display_name -}}:</span>
                            <span class="cart__product-option-value">{{- display_value -}}</span>
                          </li>
                        {%- endfor -%}
                      {%- endif -%}
                      {%- for property in item.properties -%}
                        {%- assign property_first_char = property.first | slice: 0 -%}
                        {%- if property.last != blank and property_first_char != '_' -%}
                          <li class="cart__product-option">
                            <span class="cart__product-option-name">{{- property.first -}}:</span>
                            <span class="cart__product-option-value">
                              {%- if property.last contains '/uploads/' -%}
                                <a class="lightbox" href="{{ property.last }}" target="_blank">{{ 'cart.general.uploaded_file' | t }}</a>
                              {%- else -%}
                                {{- property.last -}}
                              {%- endif -%}
                            </span>
                          </li>
                        {%- endif -%}
                      {%- endfor -%}
                      {%- if item.selling_plan_allocation.selling_plan -%}
                        <li class="cart__product-option">{{- item.selling_plan_allocation.selling_plan.name -}}</li>
                      {%- endif -%}
                    </ul>
                  {%- endif -%}

                  {% if item.line_level_discount_allocations.size > 0 %}
                    {% for discount_allocation in item.line_level_discount_allocations %}
                      <p class="applied_discount">
                        {{ discount_allocation.discount_application.title }} (- <span class="money">{% render 'price-element', price: discount_allocation.amount %}</span>)
                      </p>
                    {% endfor %}
                  {% endif %}
                </div>
              </div>

              <!-- Price -->
              <div class="cart-table__col cart-table__col--price">
                <span class="cart-item__price">
                  {% if item.line_level_discount_allocations.size > 0 %}
                    <span class="money cart-item__price--sale">{% render 'price-element', price: item.final_price %}</span>
                    <span class="money cart-item__price--was">{% render 'price-element', price: item.original_price %}</span>
                  {% else %}
                    <span class="money">{% render 'price-element', price: item.original_price %}</span>
                  {% endif %}
                </span>
                {%
                  render 'unit-price',
                  item: item,
                  class: 'cart__item-unit-price'
                %}
              </div>

              <!-- Quantity stepper -->
              <div class="cart-table__col cart-table__col--quantity">
                <div class="cart-qty-stepper">
                  <button type="button" class="cart-qty-btn cart-qty-minus" aria-label="Decrease quantity" data-line="{{ forloop.index }}">
                    <svg width="12" height="2" viewBox="0 0 12 2" fill="none" xmlns="http://www.w3.org/2000/svg"><rect width="12" height="2" fill="currentColor"/></svg>
                  </button>
                  <input
                    type="number"
                    min="0"
                    class="quantity cart-qty-input"
                    name="updates[]"
                    id="updates_{{ item.id }}"
                    value="{{ item.quantity }}"
                    data-line-id="{{ forloop.index }}"
                    aria-label="{{ 'cart.general.quantity' | t }}"
                    {% if settings.limit_quantity and item.variant.inventory_management != blank and item.variant.inventory_quantity > 0 and item.variant.inventory_policy == "deny" %}max="{{ item.variant.inventory_quantity }}"{% endif %}
                  />
                  <button type="button" class="cart-qty-btn cart-qty-plus" aria-label="Increase quantity" data-line="{{ forloop.index }}">
                    <svg width="12" height="12" viewBox="0 0 12 12" fill="none" xmlns="http://www.w3.org/2000/svg"><rect x="5" width="2" height="12" fill="currentColor"/><rect y="5" width="12" height="2" fill="currentColor"/></svg>
                  </button>
                </div>
              </div>

              <!-- Total + remove -->
              <div class="cart-table__col cart-table__col--total">
                <span class="cart-item__total money">
                  {% if item.line_level_discount_allocations.size > 0 %}
                    {% render 'price-element', price: item.final_line_price %}
                  {% else %}
                    {% render 'price-element', price: item.original_line_price %}
                  {% endif %}
                </span>
                <a
                  href="{{ routes.cart_change_url }}?line={{ forloop.index }}&quantity=0"
                  class="cart-item__remove"
                  title="{{ 'cart.general.remove' | t }}"
                  aria-label="{{ 'cart.general.remove' | t }}"
                >
                  <svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M2 4h12M5 4V3a1 1 0 011-1h4a1 1 0 011 1v1M6 7v5M10 7v5M3 4l1 9a1 1 0 001 1h6a1 1 0 001-1l1-9" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </a>
              </div>

            </div><!-- /.cart-table__row -->
          {% endfor %}
        </div><!-- /.cart-table__body -->

        <!-- Footer: totals + checkout -->
        <div class="cart-page__footer">

          {% if cart.cart_level_discount_applications != blank %}
            <div class="cart-page__discounts">
              {% for discount_application in cart.cart_level_discount_applications %}
                <div class="cart-page__discount-row">
                  <span>{{ 'cart.general.discount' | t }}: {{ discount_application.title }}</span>
                  <span class="money">- {% render 'price-element', price: discount_application.total_allocated_amount %}</span>
                </div>
              {% endfor %}
            </div>
          {% endif %}

          <div class="cart-page__subtotal-row">
            <span class="cart-page__subtotal-label">{{ 'cart.general.subtotal' | t }}</span>
            <span class="cart-page__subtotal-amount money">{% render 'price-element', price: cart.total_price %}</span>
          </div>

          <p class="cart-page__tax-label">{{ taxes_shipping_checkout }}</p>

          {% if section.settings.display_special_instructions %}
            <label for="cart-note" class="cart-page__note-label">{{ 'cart.general.note' | t: shop_name: shop.name }}:</label>
            <textarea id="cart-note" name="note" rows="3" class="cart-page__note">{{ cart.note }}</textarea>
          {% endif %}

          {% if settings.display_tos_checkbox %}
            <div class="tos_checkbox">
              <input type="checkbox" class="tos_agree" id="cart_agree" required />
              <label class="tos_label" for="cart_agree">{{ settings.tos_richtext }}</label>
            </div>
          {% endif %}

          <p class="add-to-cart-wrap">
            <noscript>
              <input type="submit" name="update" value="{{ 'cart.general.update' | t }}" class="cart-button-update action_button action_button--secondary">
            </noscript>
            <input type="submit" class="action_button add_to_cart" id="checkout" name="checkout" value="{{ 'cart.general.checkout' | t }}" />
          </p>

          {% if content_for_additional_checkout_buttons %}
            <div class="additional-checkout-buttons additional-checkout-buttons--vertical">
              {{ content_for_additional_checkout_buttons }}
            </div>
          {% endif %}

        </div><!-- /.cart-page__footer -->

      </form>

    {% endif %}
  </div><!-- /.cart-page__wrapper -->
</section>

<script>
(function() {
  // Quantity stepper: +/- buttons update the hidden input and auto-submit
  document.querySelectorAll('.cart-qty-minus, .cart-qty-plus').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var row = btn.closest('.cart-table__row');
      var input = row.querySelector('.cart-qty-input');
      var val = parseInt(input.value, 10) || 0;
      if (btn.classList.contains('cart-qty-minus')) {
        val = Math.max(0, val - 1);
      } else {
        var max = input.getAttribute('max');
        if (max) { val = Math.min(parseInt(max, 10), val + 1); }
        else { val = val + 1; }
      }
      input.value = val;
      document.getElementById('cart_form').submit();
    });
  });
})();
</script>

{% schema %}
  {
    "name": "Cart page",
    "class": "shopify-section--cart-template",
    "settings": [
      {
        "type": "checkbox",
        "id": "display_special_instructions",
        "label": "Show \"note\" text box"
      },
      {
        "type": "header",
        "content": "Continue shopping button"
      },
      {
        "type": "checkbox",
        "id": "display_continue_shopping",
        "label": "Show \"continue shopping\" link",
        "default": true
      },
      {
        "type": "url",
        "id": "continue_shopping_link",
        "label": "Link"
      }
    ]
  }
{% endschema %}
